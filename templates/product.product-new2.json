        "heading_size": "title-md",
        "heading_alignment": "text-left md:items-end md:flex-row",
        "heading_tag": "h2",
        "subheading": "",
        "description": "<p>Unlock ultimate energy efficiency by pairing your spa with our EnergyBundle™ and Premium Cover. This system boosts efficiency by an additional 30%, locking in your 40°C soak for just £2 a day.</p>",
